{
  "name": "my-playwright-monorepo",
  "version": "1.0.0",
  "description": "Playwright monorepo for multiple showcases",
  "private": true,
  "workspaces": [
    "showcase-*"
  ],
  "scripts": {
    "test": "playwright test",
    "test:all": "playwright test",
    "test:contract": "playwright test --project=showcase-contract-testen:contract-api",
    "test:allure": "npm --workspace allure3 test",
    "allure:generate": "npm --workspace allure3 run allure:generate",
    "allure:open": "npm --workspace allure3 run allure:open",
    "test:smoke": "playwright test --grep @smoke",
    "test:visual": "playwright test --grep @visual",
    "test:deep": "playwright test --grep @deep",
    "report": "playwright show-report --host 127.0.0.1 --port 9333"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
